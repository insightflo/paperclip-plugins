#!/bin/bash
# System Garden KG 자동 갱신 — post-commit hook (가즈아)
# 소스 코드 변경 시 KG 메타 갱신 → System Garden 빌드 → 서버 리로드

set -euo pipefail

KG_DIR=".understand-anything"
PLUGIN_DIR="/Users/kwak/Projects/ai/paperclip/packages/plugins/system-garden"
LOG="/tmp/system-garden-kg-update-gazua.log"

# 변경된 파일 중 소스 코드가 있는지 확인
CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)
HAS_SOURCE=$(echo "$CHANGED" | grep -E '\.(py|sh|json)$' || true)

if [ -z "$HAS_SOURCE" ]; then
    exit 0
fi

# 백그라운드에서 실행
(
    echo "[$(date '+%H:%M:%S')] 가즈아 KG update triggered by commit $(git rev-parse --short HEAD)" >> "$LOG"

    # KG gitCommitHash 갱신
    if [ -f "$KG_DIR/knowledge-graph.json" ]; then
        python3 -c "
import json, subprocess
kg_path = '$KG_DIR/knowledge-graph.json'
with open(kg_path) as f:
    kg = json.load(f)
new_hash = subprocess.check_output(['git', 'rev-parse', 'HEAD']).decode().strip()
if kg.get('project', {}).get('gitCommitHash') != new_hash:
    kg['project']['gitCommitHash'] = new_hash
    kg['project']['analyzedAt'] = __import__('datetime').datetime.now().isoformat()
    with open(kg_path, 'w') as f:
        json.dump(kg, f, ensure_ascii=False)
    print(f'KG hash updated: {new_hash[:8]}')
" >> "$LOG" 2>&1
    fi

    # System Garden 빌드 (KG가 빌드 타임 임베딩이므로)
    if command -v pnpm &>/dev/null && [ -d "$PLUGIN_DIR" ]; then
        cd "$PLUGIN_DIR" && pnpm build >> "$LOG" 2>&1
        echo "[$(date '+%H:%M:%S')] Build complete" >> "$LOG"
    fi

    # 서버 리로드
    touch /Users/kwak/Projects/ai/paperclip/server/src/index.ts
    echo "[$(date '+%H:%M:%S')] Server reload triggered" >> "$LOG"

) &>/dev/null &

exit 0
